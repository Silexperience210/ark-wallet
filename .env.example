# Example environment file for local Android builds.
# Copy this file to a SECURE location OUTSIDE the repository (e.g. ~/.ozark-keystore/.env)
# and fill in your real values. NEVER commit real secrets to Git.

ANDROID_KEYSTORE_PATH=C:\Users\<user>\.ozark-keystore\ozark-wallet.keystore
ANDROID_KEYSTORE_PASSWORD=CHANGE_ME
ANDROID_KEY_ALIAS=ozark
ANDROID_KEY_PASSWORD=CHANGE_ME
